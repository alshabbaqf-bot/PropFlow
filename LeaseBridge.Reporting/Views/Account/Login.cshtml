@model LeaseBridge.Reporting.ViewModel.LoginViewModel
@{
    ViewData["Title"] = "Log in";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="page-container d-flex align-items-start pt-4">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card card-modern border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">

                    <div class="auth-header text-center" style="padding: 30px 20px; background: var(--navy-blue); color: white;">
                        <p class="text-white-50 small fw-bold text-uppercase mb-1" style="letter-spacing: 2px; font-size: 0.8rem;">Lease Bridge</p>
                        <h2 class="fw-bold m-0" style="letter-spacing: -0.5px;">Welcome Back!</h2>
                        <div class="mx-auto mt-2" style="height: 2px; width: 30px; background: rgba(255,255,255,0.2); border-radius: 2px;"></div>
                    </div>

                    <div class="card-body p-4 p-md-5">
                        <form asp-action="Login" method="post">
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-navy text-uppercase mb-1" style="font-size: 0.75rem; letter-spacing: 0.5px;">Email</label>
                                <input asp-for="Email" class="form-control modern-input" placeholder="Email"
                                       style="padding: 12px 15px; border-radius: 10px; border: 1px solid #ddd;">
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <label class="form-label small fw-bold text-navy text-uppercase m-0" style="font-size: 0.75rem; letter-spacing: 0.5px;">Password</label>
                                </div>
                                <input asp-for="Password" class="form-control modern-input" placeholder="Password"
                                       style="padding: 12px 15px; border-radius: 10px; border: 1px solid #ddd;">
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4 d-flex justify-content-between align-items-center">
                                <div class="form-check">
                                    <input asp-for="RememberMe" class="form-check-input" id="rememberMe">
                                    <label class="form-check-label small text-muted" for="rememberMe">Remember me</label>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-navy w-100 py-3 fw-bold shadow-sm mb-3" style="border-radius: 10px;">
                                Login
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

