@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="container py-5">
    <div class="mb-5">
        <h2 class="fw-bold text-navy mb-1">Welcome Back!</h2>
        <p class="text-muted">High level overview of your properties and operations.</p>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 h-100 p-3">
                <div class="card-body text-center">
                    <div class="d-flex justify-content-center align-items-center mb-3">
                        <div class="bg-light-blue p-2 rounded-circle">
                            <i class="bi bi-building fs-4 text-navy"></i>
                        </div>
                    </div>
                    <h6 class="text-muted mb-2 small fw-bold text-uppercase">Total Units</h6>
                    <h3 class="fw-bold text-navy mb-0">42</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 h-100 p-3">
                <div class="card-body text-center">
                    <div class="d-flex justify-content-center align-items-center mb-3">
                        <div class="bg-light-blue p-2 rounded-circle">
                            <i class="bi bi-people fs-4 text-navy"></i>
                        </div>
                    </div>
                    <h6 class="text-muted mb-2 small fw-bold text-uppercase">Active Tenants</h6>
                    <h3 class="fw-bold text-navy mb-0">38</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 h-100 p-3">
                <div class="card-body text-center">
                    <div class="d-flex justify-content-center align-items-center mb-3">
                        <div class="bg-light-blue p-2 rounded-circle">
                            <i class="bi bi-tools fs-4 text-navy"></i>
                        </div>
                    </div>
                    <h6 class="text-muted mb-2 small fw-bold text-uppercase">Maintenance</h6>
                    <h3 class="fw-bold text-navy mb-0">12</h3>
                    <small class="text-muted">Pending</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 h-100 p-3">
                <div class="card-body text-center">
                    <div class="d-flex justify-content-center align-items-center mb-3">
                        <div class="bg-light-blue p-2 rounded-circle">
                            <i class="bi bi-door-open fs-4 text-navy"></i>
                        </div>
                    </div>
                    <h6 class="text-muted mb-2 small fw-bold text-uppercase">Available Units</h6>
                    <h3 class="fw-bold text-navy mb-0">4</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <h5 class="fw-bold text-navy mb-4">Quick Navigation</h5>
            <div class="row g-3">
                <div class="col-6">
                    <a asp-controller="Units" asp-action="Index" class="text-decoration-none">
                        <div class="card border p-3 hover-lift shadow-sm">
                            <div class="card-body text-center">
                                <i class="bi bi-house-add fs-2 text-navy mb-2"></i>
                                <h6 class="fw-bold text-dark mb-0">Manage Units</h6>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-6">
                    <a asp-controller="Tenants" asp-action="Index" class="text-decoration-none">
                        <div class="card border p-3 hover-lift shadow-sm">
                            <div class="card-body text-center">
                                <i class="bi bi-person-gear fs-2 text-navy mb-2"></i>
                                <h6 class="fw-bold text-dark mb-0">Manage Tenants</h6>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-6">
                    <a asp-controller="Maintenance" asp-action="Index" class="text-decoration-none">
                        <div class="card border p-3 hover-lift shadow-sm">
                            <div class="card-body text-center">
                                <i class="bi bi-clipboard-data fs-2 text-navy mb-2"></i>
                                <h6 class="fw-bold text-dark mb-0">Maintenance Log</h6>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-6">
                    <a asp-controller="Reports" asp-action="Index" class="text-decoration-none">
                        <div class="card border p-3 hover-lift shadow-sm">
                            <div class="card-body text-center">
                                <i class="bi bi-file-earmark-bar-graph fs-2 text-navy mb-2"></i>
                                <h6 class="fw-bold text-dark mb-0">View Reports</h6>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <h5 class="fw-bold text-navy mb-4">Recent Activity</h5>
            <div class="card shadow-sm border-0 p-3 h-100">
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <div class="list-group-item border-0 px-0 mb-3">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="bg-success-subtle p-2 rounded me-3">
                                        <i class="bi bi-check-circle text-success"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 fw-bold small">Payment Received</p>
                                        <small class="text-muted">Unit 302 - 350 BHD</small>
                                    </div>
                                </div>
                                <small class="text-muted">2h ago</small>
                            </div>
                        </div>
                        <div class="list-group-item border-0 px-0 mb-3">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="bg-warning-subtle p-2 rounded me-3">
                                        <i class="bi bi-tools text-warning"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 fw-bold small">Maintenance Request</p>
                                        <small class="text-muted">Unit 105 - Leaking Tap</small>
                                    </div>
                                </div>
                                <small class="text-muted">5h ago</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>