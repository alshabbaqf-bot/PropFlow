@{
    ViewData["Title"] = "Tenant Dashboard";
}

<div class="container py-5">
    <div class="mb-5">
        <h2 class="fw-bold text-navy mb-1">Welcome back!</h2>
        <p class="text-muted">Quick overview of your residency at Lease Bridge.</p>
    </div>

    <div class="row g-4 mb-4 justify-content-center">
        <div class="col-md-4">
            <div class="card card-custom h-100 p-4 border border-2">
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <i class="bi bi-file-earmark-text fs-1 text-navy mb-3"></i>
                    <h6 class="text-muted">Current Lease</h6>
                    <h3 class="fw-bold text-navy mb-0">Active</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-custom h-100 p-4 border border-2">
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <i class="bi bi-wallet2 fs-1 text-navy mb-3"></i>
                    <h6 class="text-muted">Next Payment</h6>
                    <h3 class="fw-bold text-navy">350 BHD</h3>
                    <small class="text-danger fw-bold">Due: May 15, 2026</small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-custom h-100 p-4 border border-2">
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <i class="bi bi-tools fs-1 text-navy mb-3"></i>
                    <h6 class="text-muted">Maintenance</h6>
                    <h3 class="fw-bold text-navy mb-0">0 Pending</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="py-4"></div>

    <h5 class="fw-bold text-navy mb-4">Quick Navigation</h5>
    <div class="row g-4 text-center">
        <div class="col-6 col-md-3">
            <a asp-controller="Tenant" asp-action="MyLease" class="text-decoration-none">
                <div class="card card-custom p-4 hover-lift h-100 border" style="border-color: var(--navy-blue) !important;">
                    <i class="bi bi-house-door fs-2 text-navy mb-2"></i>
                    <h6 class="fw-bold text-black mb-0">My Leases</h6>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Tenant" asp-action="Payments" class="text-decoration-none">
                <div class="card card-custom p-4 hover-lift h-100 border" style="border-color: var(--navy-blue) !important;">
                    <i class="bi bi-credit-card fs-2 text-navy mb-2"></i>
                    <h6 class="fw-bold text-black mb-0">Payments</h6>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Maintenance" asp-action="Create" class="text-decoration-none">
                <div class="card card-custom p-4 hover-lift h-100 border" style="border-color: var(--navy-blue) !important;">
                    <i class="bi bi-wrench-adjustable fs-2 text-navy mb-2"></i>
                    <h6 class="fw-bold text-black mb-0">Maintenance</h6>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Units" asp-action="Browse" class="text-decoration-none">
                <div class="card card-custom p-4 hover-lift h-100 border" style="border-color: var(--navy-blue) !important;">
                    <i class="bi bi-search fs-2 text-navy mb-2"></i>
                    <h6 class="fw-bold text-black mb-0">Browse Units</h6>
                </div>
            </a>
        </div>
    </div>
</div>