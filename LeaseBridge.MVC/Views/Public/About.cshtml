@{
    ViewData["Title"] = "About Us";
}

<section class="container py-5" style="margin-top: 20px;">
    <div class="row align-items-center g-5 mb-5">
        <div class="col-lg-6">
            <h6 class="text-navy fw-bold text-uppercase mb-3" style="letter-spacing: 2px;">About Lease Bridge</h6>
            <h2 class="display-5 fw-bold mb-4 text-navy">Smart Property Leasing & Maintenance Platform</h2>
            <p class="lead text-muted mb-4">
                Lease Bridge is a web-based property management system that simplifies leasing and maintenance processes.
                The platform allows tenants, staff, and administrators to manage properties, track maintenance requests,
                and communicate efficiently through a centralized digital solution.
            </p>
        </div>
        <div class="col-lg-6">
            <div class="position-relative">
                <img src="https://i.pinimg.com/1200x/b1/26/5b/b1265b6d8e3389368bba16cec1e27378.jpg"
                     class="img-fluid rounded-4 shadow-lg border" alt="Corporate Office">
            </div>
        </div>
    </div>

    <div class="row g-4 pt-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 position-relative overflow-hidden hover-lift" style="border-radius: 15px; background: #d1dce8;">
                <div class="d-flex align-items-center mb-3">
                    <h5 class="fw-bold m-0 text-navy"><i class="bi bi-check-circle-fill me-2 text-navy"></i>Our Vision</h5>
                </div>
                <p class="text-muted small lh-lg" style="position: relative; z-index: 1;">
                    To provide a reliable and efficient digital platform that improves property leasing
                    and maintenance management for property owners, tenants, and staff.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 position-relative overflow-hidden hover-lift" style="border-radius: 15px; background: #d1dce8;">
                <div class="d-flex align-items-center mb-3">
                    <h5 class="fw-bold m-0 text-navy"><i class="bi bi-check-circle-fill me-2 text-navy"></i>Our Mission</h5>
                </div>
                <p class="text-muted small lh-lg" style="position: relative; z-index: 1;">
                    To simplify property management processes by enabling users to manage leases,
                    submit maintenance requests, and access information through a secure web-based system.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 position-relative overflow-hidden hover-lift" style="border-radius: 15px; background: #d1dce8;">

                <div class="d-flex align-items-center mb-3">

                    <h5 class="fw-bold m-0 text-navy"><i class="bi bi-check-circle-fill me-2 text-navy"></i>Our Values</h5>
                </div>
                <p class="text-muted small lh-lg" style="position: relative; z-index: 1;">
                    We focus on system reliability, data security, user-friendly design, and accurate
                    information management to ensure a smooth and transparent leasing experience.
                </p>
            </div>
        </div>
    </div>
</section>

