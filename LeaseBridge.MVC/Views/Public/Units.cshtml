@{
    ViewData["Title"] = "Units";
}

<section class="position-relative text-white mb-5" style="height:320px;">
    <img src="https://i.pinimg.com/736x/60/90/21/60902186767bbd832584f9afc238c33a.jpg"
         class="position-absolute w-100 h-100"
         style="object-fit:cover; z-index:1;" alt="Hero">

    <div class="position-absolute w-100 h-100"
         style="background:rgba(30,52,109,0.8); z-index:2;"></div>

    <div class="container h-100 d-flex flex-column justify-content-center align-items-center text-center position-relative"
         style="z-index:3;">
        <h2 class="fw-bold mb-4">
            Find Your Next Lease
        </h2>

        <form class="bg-white p-3 rounded-3 shadow-lg w-100" style="max-width:900px;">
            <div class="row g-2 align-items-center text-dark">
                <div class="col-md-4 border-end">
                    <label class="x-small text-muted d-block text-start ps-2 fw-bold text-uppercase" style="font-size: 0.7rem;">
                        Location
                    </label>
                    <input name="location"
                           class="form-control form-control-sm border-0 shadow-none"
                           placeholder="Enter location">
                </div>

                <div class="col-md-4 border-end">
                    <label class="x-small text-muted d-block text-start ps-2 fw-bold text-uppercase" style="font-size: 0.7rem;">
                        Category
                    </label>
                    <select name="category"
                            class="form-select form-select-sm border-0 shadow-none">
                        <option value="">All</option>
                        <option value="Residential">Residential</option>
                        <option value="Commercial">Commercial</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <button type="button"
                            onclick="alert('Search functionality will be available soon!')"
                            class="btn btn-navy w-100 py-2 rounded-2 fw-bold shadow-sm">
                        Search
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>