<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LeaseBridge</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm py-3 mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold text-navy" asp-controller="Home" asp-action="Index">LEASE BRIDGE</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto gap-lg-4">
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-controller="Public" asp-action="MaintenanceLookup">Track Maintenance</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-controller="Public" asp-action="Units">Units</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link custom-nav-link" asp-controller="Public" asp-action="About">About Us</a>
                        </li>
                    </ul>
                    <!--login button-->
                    <a class="btn btn-navy px-4 rounded-2" asp-controller="Account" asp-action="Login">Login</a>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <!--Footer -->
    <footer class="bg-dark text-white pt-5 pb-3 mt-auto">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold text-white mb-3">LEASE BRIDGE</h5>
                    <p class="small text-white-50">Providing seamless property management solutions. Efficiency and transparency in every lease.</p>

                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="fw-bold mb-3">Quick Links</h6>
                    <ul class="list-unstyled small text-white-50">
                        <li class="mb-2"><a href="/" class="text-decoration-none text-reset">Home</a></li>
                        <li class="mb-2"><a href="/Public/Units" class="text-decoration-none text-reset">Browse Units</a></li>
                        <li class="mb-2"><a href="/Public/MaintenanceLookup" class="text-decoration-none text-reset">Track Request</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold mb-3">Support</h6>
                    <p class="small text-white-50 mb-1"><i class="bi bi-geo-alt me-2"></i> Isa Town, Bahrain</p>
                    <p class="small text-white-50 mb-1"><i class="bi bi-envelope me-2"></i> support@leasebridge.com</p>
                    <p class="small text-white-50"><i class="bi bi-telephone me-2"></i> +973 1755621</p>
                </div>

            </div>
            <hr class="border-secondary opacity-25">
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center small text-white-50">
                <p class="mb-0">&copy; 2026 LeaseBridge Platform. All rights reserved.</p>
                <div class="d-flex gap-3">
                    <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-reset">Privacy Policy</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>