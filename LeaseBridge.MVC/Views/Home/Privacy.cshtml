@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="border-bottom pb-4 mb-5">
                <h2 class="fw-bold text-navy display-6">Privacy Policy</h2>
                <p class="lead">Lease Bridge is committed to protecting the privacy and security of our users' personal and professional data.</p>
            </div>

            <div class="privacy-section mb-5">
                <h5 class="fw-bold text-navy mb-3">1. Information Collection and Usage</h5>
                <p class="text-secondary">
                    We collect sensitive personal identifiers including, but not limited to, <strong>Full Names, Email, and Contact Information</strong>. This data is strictly utilized for the execution of legally binding lease agreements and tenant verification processes.
                </p>
            </div>

            <div class="privacy-section mb-5">
                <h5 class="fw-bold text-navy mb-3">2. Maintenance and Service Records</h5>
                <p class="text-secondary">
                    To maintain the highest quality of service, all maintenance requests, facility reports, and communication logs are recorded. These records serve as a historical audit trail to ensure accountability and operational efficiency.
                </p>
            </div>

            <div class="privacy-section mb-5">
                <h5 class="fw-bold text-navy mb-3">3. Data Security and Encryption</h5>
                <p class="text-secondary">
                    We strive to protect your data through secure database practices to prevent unauthorized access and ensure information integrity
            </div>

            <div class="bg-light p-4 rounded-3 border-start border-4 border-navy">
                <h6 class="fw-bold text-navy mb-2">Compliance Statement</h6>
                <p class="small text-muted mb-0">
                    By using the Lease Bridge platform, you acknowledge and consent to the data handling practices outlined in this policy. For further inquiries regarding your data, please contact our legal department.
                </p>
            </div>
        </div>
    </div>
</div>