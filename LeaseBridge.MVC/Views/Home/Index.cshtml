@{
    ViewData["Title"] = "Home Page";
}

<section class="hero-section text-center">
    <div class="container">
        <h1 class="display-3 fw-bold mb-4">Smarter Leasing. Better Living.</h1>
        <p class="lead mb-5 ">A centralized platform for managing properties, tenants, and maintenance requests efficiently..</p>
        <a asp-controller="Public" asp-action="Units" class="btn btn-lg btn-light px-5 rounded-pill fw-bold text-navy">Explore Units</a>
    </div>
</section>
<section class="container py-5 my-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-navy">Explore Our Platform</h2>
        <div class="mx-auto bg-primary mb-3" style="width: 50px; height: 3px;"></div>
        <p class="text-muted">
            Lease Bridge provides tools to manage property units, maintenance requests, and tenant information in one secure system.
        </p>
    </div>
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="service-card p-4 rounded-4 shadow-sm h-100 border-0" style="background-color: #d1dce8;">
                <div class="icon-box mb-3"><i class="bi bi-tools fs-2 text-navy"></i></div>
                <h4 class="fw-bold text-navy">Smart Maintenance</h4>
                <p class="text-muted small">
                    Submit maintenance requests online and monitor their status until completion.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="service-card p-4 rounded-4 shadow-sm h-100 border-0" style="background-color: #cce5ff;">
                <div class="icon-box mb-3"><i class="bi bi-house-check fs-2 text-primary"></i></div>
                <h4 class="fw-bold text-dark">Unit Reservations</h4>
                <p class="text-muted small"> View available units, check details, and request bookings through the platform.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="service-card p-4 rounded-4 shadow-sm h-100 border-0" style="background-color: #e2e8f0;">
                <div class="icon-box mb-3"><i class="bi bi-shield-lock fs-2 text-secondary"></i></div>
                <h4 class="fw-bold text-dark">Secure Payments</h4>
                <p class="text-muted small"> Maintain digital records of lease payments and transaction history securely.</p>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center bg-gray-section p-5 rounded-4 shadow-sm border-0">
            <div class="col-lg-6">
                <h6 class="text-primary fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">The Advantage</h6>
                <h2 class="fw-bold mb-4 text-navy">Why Choose Lease Bridge?</h2>

                <div class="feature-list mt-4">
                    <div class="d-flex mb-4">
                        <div class="icon-circle bg-primary-soft me-3">
                            <span class="number-icon-box mb-4">1</span>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Live Inventory Management</h6>
                            <p class="text-muted small mb-0">Monitor property and unit availability with up-to-date information..</p>
                        </div>
                    </div>

                    <div class="d-flex mb-4">
                        <div class="icon-circle bg-primary-soft me-3">
                            <div class="icon-circle bg-primary-soft">
                                <span class="number-icon-box mb-4">2</span>
                            </div>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Public Maintenance Lookup</h6>
                            <p class="text-muted small mb-0">Users can check the progress of maintenance requests using a reference number.</p>
                        </div>
                    </div>

                    <div class="d-flex mb-4">
                        <div class="icon-circle bg-primary-soft me-3">
                            <span class="number-icon-box mb-4">3</span>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Instant Notification System</h6>
                            <p class="text-muted small mb-0">Receive updates when maintenance requests or unit statuses change.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 text-center mt-4 mt-lg-0">
                <div class="position-relative">
                    <img src="https://i.pinimg.com/1200x/2a/66/ca/2a66caf548d09b5ce362949c26a1ea06.jpg"
                         class="img-fluid rounded-4 shadow-lg"
                         alt="Leasing and Maintenance Management"
                         style="max-height: 450px; width: 100%; object-fit: cover;">
                </div>
            </div>
        </div>
    </div>
</section>

