@{
    ViewData["Title"] = "Staff Dashboard";
}

<div class="container py-5">
    <div class="mb-5">
        <h2 class="fw-bold text-navy mb-1">Service Portal</h2>
        <p class="text-muted">Manage your assigned maintenance tasks and updates.</p>
    </div>

    <div class="row g-4 mb-5 justify-content-center">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 p-3">
                <div class="card-body text-center">
                    <div class="d-flex justify-content-center align-items-center mb-3">
                        <div class="bg-light-blue p-2 rounded-circle">
                            <i class="bi bi-clipboard-check fs-4 text-navy"></i>
                        </div>
                    </div>
                    <h6 class="text-muted mb-2 small fw-bold text-uppercase">Assigned Tasks</h6>
                    <h3 class="fw-bold text-navy mb-0">--</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 p-3">
                <div class="card-body text-center">
                    <div class="d-flex justify-content-center align-items-center mb-3">
                        <div class="bg-light-blue p-2 rounded-circle">
                            <i class="bi bi-check2-circle fs-4 text-navy"></i>
                        </div>
                    </div>
                    <h6 class="text-muted mb-2 small fw-bold text-uppercase">Completed Tasks</h6>
                    <h3 class="fw-bold text-navy mb-0">--</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 p-3">
                <div class="card-body text-center">
                    <div class="d-flex justify-content-center align-items-center mb-3">
                        <div class="bg-light-blue p-2 rounded-circle">
                            <i class="bi bi-clock-history fs-4 text-navy"></i>
                        </div>
                    </div>
                    <h6 class="text-muted mb-2 small fw-bold text-uppercase">Pending Requests</h6>
                    <h3 class="fw-bold text-navy mb-0">--</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold text-navy mb-0">Current Maintenance Jobs</h5>
                <span class="badge bg-light text-navy border">Total: 0</span>
            </div>

            <div class="card shadow-sm border-0 bg-white">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Request ID</th>
                                <th>Unit</th>
                                <th>Issue</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-inbox fs-1 text-muted d-block mb-2"></i>
                                    <p class="text-muted mb-0">No maintenance tasks assigned yet.</p>
                                </td>
                            </tr>

                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <h5 class="fw-bold text-navy mb-4">Quick Actions</h5>
            <div class="d-grid gap-3">
                <a asp-controller="Maintenance" asp-action="AssignedTasks" class="text-decoration-none">
                    <div class="card border p-3 hover-lift shadow-sm bg-white">
                        <div class="card-body d-flex align-items-center">
                            <i class="bi bi-tools fs-3 text-navy me-3"></i>
                            <h6 class="fw-bold text-dark mb-0">View Assigned Tasks</h6>
                        </div>
                    </div>
                </a>
                <a asp-controller="Maintenance" asp-action="UpdateStatus" class="text-decoration-none">
                    <div class="card border p-3 hover-lift shadow-sm bg-white">
                        <div class="card-body d-flex align-items-center">
                            <i class="bi bi-arrow-repeat fs-3 text-navy me-3"></i>
                            <h6 class="fw-bold text-dark mb-0">Update Task Status</h6>
                        </div>
                    </div>
                </a>
            </div>


        </div>
    </div>
</div>

